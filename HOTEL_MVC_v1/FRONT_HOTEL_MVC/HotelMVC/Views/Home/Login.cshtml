@model HotelMVC.Models.LoginRequest
@{
    ViewData["Title"] = "Iniciar sesión";
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>HotelOS - Login</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
<div class="login-screen">
    <div class="login-card">
        <div class="login-logo">
            <h1>HOTEL<span class="accent">OS</span></h1>
            <p>Sistema de gestión hotelera</p>
        </div>

        <form asp-action="Login" method="post">
            @if (ViewBag.Error != null)
            {
                <div class="alert-error">@ViewBag.Error</div>
            }

            <div class="form-group">
                <label asp-for="Username">Usuario</label>
                <input asp-for="Username" class="form-control" placeholder="username" autocomplete="username" />
            </div>

            <div class="form-group">
                <label asp-for="Password">Contraseña</label>
                <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" autocomplete="current-password" />
            </div>

            <button type="submit" class="btn btn-primary btn-block">Entrar →</button>
        </form>
    </div>
</div>
</body>
</html>
