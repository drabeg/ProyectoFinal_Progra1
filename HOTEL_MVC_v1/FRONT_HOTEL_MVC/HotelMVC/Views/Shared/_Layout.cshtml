<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>HotelOS - @ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>

@if (Context.Session.GetString("Username") != null)
{
    <div class="layout">
        <!-- SIDEBAR -->
        <aside class="sidebar">
            <div class="brand">
                <span class="brand-name">HOTEL<span class="accent">OS</span></span>
                <span class="brand-sub">MVC · Razor</span>
            </div>
            <nav class="nav">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
                   asp-controller="Home" asp-action="Index">🏠 Dashboard</a>
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Hotel" ? "active" : "")"
                   asp-controller="Hotel" asp-action="Index">🏨 Hoteles</a>
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Habitacion" ? "active" : "")"
                   asp-controller="Habitacion" asp-action="Index">🛏 Habitaciones</a>
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Cliente" ? "active" : "")"
                   asp-controller="Cliente" asp-action="Index">👤 Clientes</a>
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Empleado" ? "active" : "")"
                   asp-controller="Empleado" asp-action="Index">👔 Empleados</a>
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Reservacion" ? "active" : "")"
                   asp-controller="Reservacion" asp-action="Index">📋 Reservaciones</a>
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Usuario" ? "active" : "")"
                   asp-controller="Usuario" asp-action="Index">🔑 Usuarios</a>
            </nav>
            <div class="sidebar-footer">
                <div class="user-chip">
                    <div class="user-avatar">@(Context.Session.GetString("Username")?[0].ToString().ToUpper())</div>
                    <div class="user-info">
                        <div class="user-name">@Context.Session.GetString("Username")</div>
                        <div class="user-role">@Context.Session.GetString("Rol")</div>
                    </div>
                    <a asp-controller="Home" asp-action="Logout" class="logout-btn" title="Cerrar sesión">⏻</a>
                </div>
            </div>
        </aside>

        <!-- MAIN -->
        <main class="main">
            <div class="topbar">
                <h1 class="page-title">@ViewData["Title"]</h1>
            </div>
            <div class="content">
                @RenderBody()
            </div>
        </main>
    </div>
}
else
{
    @RenderBody()
}

</body>
</html>
