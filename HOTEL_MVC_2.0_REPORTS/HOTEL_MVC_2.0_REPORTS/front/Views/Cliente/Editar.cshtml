@model HotelMVC.Models.Cliente
@{
    ViewData["Title"] = "Editar Cliente";
}

<div class="form-card">
    <form asp-action="Editar" asp-route-id="@Model.IdCliente" method="post">
        <input type="hidden" asp-for="IdCliente" />
        <div class="form-group">
            <label asp-for="Nombre">Nombre</label>
            <input asp-for="Nombre" class="form-control" />
        </div>
        <div class="form-group">
            <label asp-for="Apellido">Apellido</label>
            <input asp-for="Apellido" class="form-control" />
        </div>
        <div class="form-group">
            <label asp-for="Dpi">DPI</label>
            <input asp-for="Dpi" class="form-control" />
        </div>
        <div class="form-group">
            <label asp-for="Telefono">Teléfono</label>
            <input asp-for="Telefono" class="form-control" />
        </div>
        <div class="form-group">
            <label asp-for="Correo">Correo</label>
            <input asp-for="Correo" class="form-control" />
        </div>
        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Actualizar</button>
            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
        </div>
    </form>
</div>
