@* ===== Views/Cliente/Index.cshtml ===== *@
@model List<HotelMVC.Models.Cliente>
@{
    ViewData["Title"] = "Clientes";
}

<div class="section-header">
    <a asp-action="Crear" class="btn btn-primary">+ Nuevo Cliente</a>
</div>

<div class="table-wrap">
    <table class="table">
        <thead>
            <tr>
                <th>ID</th><th>Nombre</th><th>Apellido</th><th>DPI</th><th>Teléfono</th><th>Correo</th><th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in Model)
            {
                <tr>
                    <td>@c.IdCliente</td>
                    <td>@c.Nombre</td>
                    <td>@c.Apellido</td>
                    <td>@c.Dpi</td>
                    <td>@c.Telefono</td>
                    <td>@c.Correo</td>
                    <td class="actions">
                        <a asp-action="Editar" asp-route-id="@c.IdCliente" class="btn btn-sm btn-edit">Editar</a>
                        <form asp-action="Eliminar" asp-route-id="@c.IdCliente" method="post" style="display:inline"
                              onsubmit="return confirm('¿Eliminar cliente @c.Nombre?')">
                            <button type="submit" class="btn btn-sm btn-danger">Eliminar</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
