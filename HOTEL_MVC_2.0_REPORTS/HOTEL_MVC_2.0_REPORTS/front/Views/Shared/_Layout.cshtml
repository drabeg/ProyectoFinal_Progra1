<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>HotelOS - @ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>

@{
    var username = Context.Session.GetString("Username");
    var rol      = Context.Session.GetString("Rol");
    var ctrl     = ViewContext.RouteData.Values["controller"]?.ToString();

    bool esAdmin       = rol == "Administrador";
    bool esSupervisor  = rol == "Supervisor";
    bool esRecepcion   = rol == "Recepcionista";
}

@if (username != null)
{
    <div class="layout">
        <!-- SIDEBAR -->
        <aside class="sidebar">
            <div class="brand">
                <span class="brand-name">HOTEL<span class="accent">OS</span></span>
                <span class="brand-sub">MVC · @rol</span>
            </div>
            <nav class="nav">

                <!-- Dashboard: todos los roles -->
                <a class="nav-link @(ctrl == "Home" ? "active" : "")"
                   asp-controller="Home" asp-action="Index">⊞ Dashboard</a>

                <!-- SECCIÓN: GESTIÓN -->
                @if (esAdmin || esSupervisor || esRecepcion)
                {
                    <div class="nav-section">Gestión</div>
                }

                @if (esAdmin)
                {
                    <a class="nav-link @(ctrl == "Hotel" ? "active" : "")"
                       asp-controller="Hotel" asp-action="Index">🏨 Hoteles</a>
                }

                @if (esAdmin || esSupervisor || esRecepcion)
                {
                    <a class="nav-link @(ctrl == "Habitacion" ? "active" : "")"
                       asp-controller="Habitacion" asp-action="Index">🛏 Habitaciones</a>
                }

                @if (esAdmin || esSupervisor || esRecepcion)
                {
                    <a class="nav-link @(ctrl == "Reservacion" ? "active" : "")"
                       asp-controller="Reservacion" asp-action="Index">📋 Reservaciones</a>
                }

                <!-- SECCIÓN: PERSONAS -->
                @if (esAdmin || esSupervisor || esRecepcion)
                {
                    <div class="nav-section">Personas</div>

                    <a class="nav-link @(ctrl == "Cliente" ? "active" : "")"
                       asp-controller="Cliente" asp-action="Index">👤 Clientes</a>
                }

                @if (esAdmin)
                {
                    <a class="nav-link @(ctrl == "Empleado" ? "active" : "")"
                       asp-controller="Empleado" asp-action="Index">👔 Empleados</a>
                }

                <!-- SECCIÓN: SISTEMA -->
                <div class="nav-section">Sistema</div>

                @if (esAdmin || esSupervisor)
                {
                    <a class="nav-link @(ctrl == "Reportes" ? "active" : "")"
                       asp-controller="Reportes" asp-action="Index">📊 Reportes</a>
                }

                @if (esAdmin)
                {
                    <a class="nav-link @(ctrl == "Usuario" ? "active" : "")"
                       asp-controller="Usuario" asp-action="Index">🔑 Usuarios</a>
                }

            </nav>

            <!-- Badge de rol -->
            <div class="sidebar-rol-badge @(rol?.ToLower())">@rol</div>

            <div class="sidebar-footer">
                <div class="user-chip">
                    <div class="user-avatar">
                        @(username?[0].ToString().ToUpper())
                    </div>
                    <div class="user-info">
                        <div class="user-name">@username</div>
                        <div class="user-role">@rol</div>
                    </div>
                    <a asp-controller="Home" asp-action="Logout"
                       class="logout-btn" title="Cerrar sesión">⏻</a>
                </div>
            </div>
        </aside>

        <!-- MAIN -->
        <main class="main">
            <div class="topbar">
                <h1 class="page-title">@ViewData["Title"]</h1>
                <div class="topbar-right">
                    <span class="topbar-user">@username</span>
                </div>
            </div>
            <div class="content">
                @* Mensajes de feedback (TempData) *@
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success">✔ @TempData["Success"]</div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger">✖ @TempData["Error"]</div>
                }

                @RenderBody()
            </div>
        </main>
    </div>
}
else
{
    @RenderBody()
}

</body>
</html>
