@model List<HotelMVC.Models.Usuario>
@{
    ViewData["Title"] = "Usuarios";
    var empleados = ViewBag.Empleados as List<HotelMVC.Models.Empleado> ?? new();
}

<div class="section-header">
    <a asp-action="Crear" class="btn btn-primary">+ Nuevo Usuario</a>
</div>

<div class="table-wrap">
    <table class="table">
        <thead>
            <tr><th>ID</th><th>Username</th><th>Rol</th><th>Empleado</th><th>Acciones</th></tr>
        </thead>
        <tbody>
            @foreach (var u in Model)
            {
                var empNombre = empleados.FirstOrDefault(e => e.IdEmpleado == u.IdEmpleado)?.Nombre ?? u.IdEmpleado.ToString();
                <tr>
                    <td>@u.IdUsuario</td>
                    <td>@u.Username</td>
                    <td><span class="badge badge-rol">@u.Rol</span></td>
                    <td>@empNombre</td>
                    <td class="actions">
                        <a asp-action="Editar" asp-route-id="@u.IdUsuario" class="btn btn-sm btn-edit">Editar</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
