@model List<HotelMVC.Models.Habitacion>
@{
    ViewData["Title"] = "Habitaciones";
    var hoteles = ViewBag.Hoteles as List<HotelMVC.Models.Hotel> ?? new();
    var tipos   = ViewBag.Tipos   as List<HotelMVC.Models.TipoHabitacion> ?? new();
}

<div class="section-header">
    <a asp-action="Crear" class="btn btn-primary">+ Nueva Habitación</a>
</div>

<div class="table-wrap">
    <table class="table">
        <thead>
            <tr><th>ID</th><th>Número</th><th>Tipo</th><th>Hotel</th><th>Estado</th><th>Acciones</th></tr>
        </thead>
        <tbody>
            @foreach (var h in Model)
            {
                var hotelNombre = hoteles.FirstOrDefault(x => x.IdHotel == h.IdHotel)?.Nombre ?? h.IdHotel.ToString();
                var tipoNombre  = tipos.FirstOrDefault(x => x.IdTipo == h.IdTipo)?.Nombre ?? h.IdTipo.ToString();
                <tr>
                    <td>@h.IdHabitacion</td>
                    <td>@h.Numero</td>
                    <td>@tipoNombre</td>
                    <td>@hotelNombre</td>
                    <td><span class="badge @(h.Estado == "Disponible" ? "badge-ok" : "badge-warn")">@h.Estado</span></td>
                    <td class="actions">
                        <a asp-action="Editar" asp-route-id="@h.IdHabitacion" class="btn btn-sm btn-edit">Editar</a>
                        <form asp-action="Eliminar" asp-route-id="@h.IdHabitacion" method="post" style="display:inline"
                              onsubmit="return confirm('¿Eliminar habitación @h.Numero?')">
                            <button type="submit" class="btn btn-sm btn-danger">Eliminar</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
