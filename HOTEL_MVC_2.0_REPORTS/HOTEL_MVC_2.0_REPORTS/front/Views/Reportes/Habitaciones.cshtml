@* Views/Reportes/Habitaciones.cshtml *@
@{
    ViewData["Title"] = "Inventario de Habitaciones";
    var datosJson = ViewBag.DatosJson as string ?? "null";
}

<div class="rpt-page">
  <div class="rpt-page-header">
    <div>
      <div class="rpt-breadcrumb"><a asp-action="Index">Reportes</a> / Habitaciones</div>
      <h2 class="rpt-page-title">🛏 Inventario de Habitaciones</h2>
      <p class="rpt-page-desc">Inventario completo de habitaciones por hotel y tipo. Solo Administrador.</p>
    </div>
    <div class="rpt-actions">
      <button class="btn btn-ghost btn-sm" onclick="window.print()">🖨 Imprimir</button>
      <button class="btn btn-ghost btn-sm" onclick="exportarCSV()">⬇ CSV</button>
    </div>
  </div>

  <div id="rptContenido"><div class="rpt-loading-msg">Cargando...</div></div>
  <div class="rpt-footer" id="rptPie" style="display:none">
    Generado: <span id="rptFecha">—</span> · Usuario: <strong>@Context.Session.GetString("Username")</strong>
  </div>
</div>

<script>
const DATOS_RAW = @Html.Raw(datosJson);
const BADGE = { Disponible:'badge-ok', Ocupada:'badge-ocu', Mantenimiento:'badge-man' };

document.addEventListener('DOMContentLoaded', () => {
  if (!DATOS_RAW) {
    document.getElementById('rptContenido').innerHTML = '<div class="rpt-error">❌ Sin datos.</div>';
    return;
  }
  const d = DATOS_RAW;

  const grupos = (d.porHotel || []).filter(h => h.total > 0).map(hotel => {
    const filas = (hotel.habitaciones || []).map(h => `
      <tr>
        <td class="td-id">${h.idHabitacion}</td>
        <td class="td-name">${h.numero}</td>
        <td class="td-muted">${h.tipo}</td>
        <td style="color:var(--accent);font-weight:600">Q${Number(h.precio||0).toFixed(2)}</td>
        <td><span class="badge ${BADGE[h.estado]||''}">${h.estado}</span></td>
      </tr>`).join('');
    return `
      <div class="rpt-group" style="margin-bottom:20px">
        <div class="rpt-group-header">
          🏨 ${hotel.nombre}
          <div style="display:flex;gap:10px;align-items:center">
            <span class="badge badge-ok">${hotel.disponibles} disp.</span>
            <span class="badge badge-ocu">${hotel.ocupadas} ocup.</span>
            <span class="rpt-group-count">${hotel.total} total</span>
          </div>
        </div>
        <div class="rpt-table-wrap">
          <table>
            <thead><tr><th>#</th><th>Número</th><th>Tipo</th><th>Precio/noche</th><th>Estado</th></tr></thead>
            <tbody>${filas}</tbody>
          </table>
        </div>
      </div>`;
  }).join('');

  // Tabla de tipos
  const tiposFilas = (d.tipos || []).map(t => `
    <tr>
      <td class="td-id">${t.idTipo}</td>
      <td class="td-name">${t.nombre}</td>
      <td class="td-muted">${t.descripcion || '—'}</td>
      <td style="color:var(--accent);font-weight:600">Q${Number(t.precio||0).toFixed(2)}</td>
      <td>${t.cantidad}</td>
    </tr>`).join('');

  document.getElementById('rptContenido').innerHTML = `
    <div class="rpt-kpi-grid" style="margin-bottom:24px">
      <div class="kpi-card"><div class="kpi-val" style="color:var(--info)">${d.totalHabitaciones}</div><div class="kpi-lbl">Total Habitaciones</div></div>
      <div class="kpi-card"><div class="kpi-val" style="color:var(--success)">${d.totalHoteles}</div><div class="kpi-lbl">Hoteles</div></div>
      <div class="kpi-card"><div class="kpi-val" style="color:var(--warn)">${d.totalTipos}</div><div class="kpi-lbl">Tipos de Habitación</div></div>
    </div>

    <div class="rpt-section-title" style="margin-bottom:10px">Tipos de Habitación</div>
    <div class="rpt-table-wrap" style="margin-bottom:28px">
      <table>
        <thead><tr><th>#</th><th>Tipo</th><th>Descripción</th><th>Precio</th><th>Cantidad</th></tr></thead>
        <tbody>${tiposFilas}</tbody>
      </table>
    </div>

    <div class="rpt-section-title" style="margin-bottom:10px">Habitaciones por Hotel</div>
    ${grupos}`;

  document.getElementById('rptFecha').textContent = new Date(d.fechaGeneracion).toLocaleString('es-GT');
  document.getElementById('rptPie').style.display = 'block';
});

function exportarCSV() {
  const tbls = document.querySelectorAll('#rptContenido table');
  const allRows = [];
  tbls.forEach(tbl => {
    [...tbl.querySelectorAll('tr')].forEach(tr => {
      allRows.push([...tr.querySelectorAll('th,td')].map(c=>`"${c.innerText.replace(/"/g,'""')}"`).join(','));
    });
    allRows.push('');
  });
  const blob = new Blob(['\uFEFF'+allRows.join('\n')],{type:'text/csv;charset=utf-8;'});
  const a = document.createElement('a'); a.href=URL.createObjectURL(blob);
  a.download='habitaciones_'+Date.now()+'.csv'; a.click();
}
</script>
<style>@@media print { .rpt-actions,.sidebar,.topbar{display:none!important;} }</style>
