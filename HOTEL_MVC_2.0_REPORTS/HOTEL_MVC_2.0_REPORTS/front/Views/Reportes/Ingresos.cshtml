@{
    ViewData["Title"] = "Reporte de Ingresos";
    var datosJson = ViewBag.DatosJson as string ?? "null";
    var desde = ViewBag.Desde as string ?? "";
    var hasta = ViewBag.Hasta as string ?? "";
}

<div class="rpt-page">

  <div class="rpt-page-header">
    <div>
      <div class="rpt-breadcrumb"><a asp-action="Index">Reportes</a> / Ingresos</div>
      <h2 class="rpt-page-title">💰 Reporte de Ingresos</h2>
      <p class="rpt-page-desc">Ingresos totales y desglosados por hotel. Filtra por rango de fechas.</p>
    </div>
    <div class="rpt-actions">
      <button class="btn btn-ghost btn-sm" onclick="imprimirReporte()">🖨 Imprimir</button>
      <button class="btn btn-ghost btn-sm" onclick="exportarCSV()">⬇ CSV</button>
    </div>
  </div>

  <!-- Filtros de fecha -->
  <form method="get" asp-action="Ingresos" class="rpt-filtros">
    <div class="filtro-group">
      <label class="field-label">Desde</label>
      <input class="field-input" type="date" name="desde" value="@desde" />
    </div>
    <div class="filtro-group">
      <label class="field-label">Hasta</label>
      <input class="field-input" type="date" name="hasta" value="@hasta" />
    </div>
    <button type="submit" class="btn btn-accent">▶ Generar</button>
    @if (!string.IsNullOrEmpty(desde) || !string.IsNullOrEmpty(hasta))
    {
      <a asp-action="Ingresos" class="btn btn-ghost">✕ Limpiar filtros</a>
    }
  </form>

  @if (!string.IsNullOrEmpty(desde) || !string.IsNullOrEmpty(hasta))
  {
    <div class="rpt-filter-badge" style="margin-bottom:16px">
      🗓 Período: @(string.IsNullOrEmpty(desde) ? "—" : desde) al @(string.IsNullOrEmpty(hasta) ? "—" : hasta)
    </div>
  }

  <div id="rptContenido">
    @if (datosJson != "null")
    {
      <div class="rpt-loading-msg">Procesando datos...</div>
    }
    else
    {
      <div class="rpt-welcome-small">
        <p>Configura el período y presiona <strong>▶ Generar</strong> para ver el reporte.</p>
      </div>
    }
  </div>

  <div class="rpt-footer" id="rptPie" style="display:none">
    Generado: <span id="rptFecha">—</span> ·
    Usuario: <strong>@Context.Session.GetString("Username")</strong> ·
    Rol: @Context.Session.GetString("Rol")
  </div>
</div>

<script>
const DATOS_RAW = @Html.Raw(datosJson);

document.addEventListener('DOMContentLoaded', () => {
  if (!DATOS_RAW) return;
  renderReporte(DATOS_RAW);
});

function fmtQ(n) { return 'Q' + Number(n||0).toFixed(2); }

function renderReporte(d) {
  const kpis = [
    { lbl:'Ingresos Totales',     val: fmtQ(d.ingresoTotal),        color:'var(--accent)' },
    { lbl:'Total Reservaciones',  val: d.totalReservaciones,         color:'var(--info)' },
    { lbl:'Promedio por Reserva', val: fmtQ(d.promedioPorReserva),  color:'var(--success)' },
  ];

  const porHotel = (d.porHotel || []).map(h => `
    <tr>
      <td class="td-name">${h.nombre}</td>
      <td>${h.totalReservaciones}</td>
      <td style="color:var(--accent);font-weight:700">${fmtQ(h.ingresoTotal)}</td>
      <td>
        <div class="rpt-bar-wrap">
          <div class="rpt-bar" style="width:${Math.round(h.porcentajeDelTotal)}px"></div>
          <span>${h.porcentajeDelTotal}%</span>
        </div>
      </td>
    </tr>`).join('');

  const detalle = (d.detalle || []).map(r => `
    <tr>
      <td class="td-id">${r.idReservacion}</td>
      <td class="td-name">${r.cliente}</td>
      <td class="td-muted">${r.hotel}</td>
      <td class="td-muted">${r.fechaInicio}</td>
      <td class="td-muted">${r.fechaFin}</td>
      <td class="td-muted">${r.noches}</td>
      <td style="color:var(--accent);font-weight:700">${fmtQ(r.total)}</td>
    </tr>`).join('');

  document.getElementById('rptContenido').innerHTML = `
    <div class="rpt-kpi-grid">
      ${kpis.map(k => `
        <div class="kpi-card">
          <div class="kpi-val" style="color:${k.color};font-size:22px">${k.val}</div>
          <div class="kpi-lbl">${k.lbl}</div>
        </div>`).join('')}
    </div>

    <div class="rpt-section-title" style="margin-bottom:10px">Ingresos por Hotel</div>
    <div class="rpt-table-wrap" style="margin-bottom:28px">
      <table>
        <thead><tr><th>Hotel</th><th>Reservaciones</th><th>Ingresos</th><th>% del Total</th></tr></thead>
        <tbody>${porHotel || '<tr><td colspan="4" style="text-align:center;color:var(--muted);padding:20px">Sin datos</td></tr>'}</tbody>
      </table>
    </div>

    <div class="rpt-section-title" style="margin-bottom:10px">Detalle de reservaciones</div>
    <div class="rpt-table-wrap">
      <table>
        <thead><tr><th>#</th><th>Cliente</th><th>Hotel</th><th>Inicio</th><th>Fin</th><th>Noches</th><th>Total</th></tr></thead>
        <tbody>${detalle || '<tr><td colspan="7" style="text-align:center;color:var(--muted);padding:20px">Sin reservaciones en el período</td></tr>'}</tbody>
        <tfoot>
          <tr>
            <td colspan="6" style="text-align:right;font-size:11px;color:var(--muted2)">TOTAL PERÍODO</td>
            <td style="color:var(--accent);font-weight:700;font-size:16px">${fmtQ(d.ingresoTotal)}</td>
          </tr>
        </tfoot>
      </table>
    </div>`;

  document.getElementById('rptFecha').textContent = new Date(d.fechaGeneracion).toLocaleString('es-GT');
  document.getElementById('rptPie').style.display = 'block';
}

function imprimirReporte() { window.print(); }
function exportarCSV() {
  const tbl = document.querySelector('#rptContenido table');
  if (!tbl) return;
  const rows = [...tbl.querySelectorAll('tr')].map(tr =>
    [...tr.querySelectorAll('th,td')].map(c => `"${c.innerText.replace(/"/g,'""')}"`).join(','));
  const blob = new Blob(['\uFEFF' + rows.join('\n')], { type:'text/csv;charset=utf-8;' });
  const a = document.createElement('a'); a.href = URL.createObjectURL(blob);
  a.download = 'reporte_ingresos_' + Date.now() + '.csv'; a.click();
}
</script>

<style>
.rpt-filtros {
  display: flex; align-items: flex-end; gap: 14px; flex-wrap: wrap;
  padding: 16px 20px; background: var(--surface2);
  border: 1px solid var(--border); border-radius: var(--r); margin-bottom: 20px;
}
.filtro-group { display: flex; flex-direction: column; gap: 6px; }
.rpt-welcome-small { padding: 32px; text-align: center; color: var(--muted2); font-size: 13px; }
@@media print { .rpt-actions, .rpt-filtros, .sidebar, .topbar { display:none!important; } }
</style>
