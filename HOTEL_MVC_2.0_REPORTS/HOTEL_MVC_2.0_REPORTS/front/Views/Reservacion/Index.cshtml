@model List<HotelMVC.Models.Reservacion>
@{
    ViewData["Title"] = "Reservaciones";
    var clientes  = ViewBag.Clientes  as List<HotelMVC.Models.Cliente>  ?? new();
    var empleados = ViewBag.Empleados as List<HotelMVC.Models.Empleado> ?? new();
    var hoteles   = ViewBag.Hoteles   as List<HotelMVC.Models.Hotel>    ?? new();
}

<div class="section-header">
    <a asp-action="Crear" class="btn btn-primary">+ Nueva Reservación</a>
</div>

<div class="table-wrap">
    <table class="table">
        <thead>
            <tr><th>ID</th><th>Cliente</th><th>Empleado</th><th>Hotel</th><th>Inicio</th><th>Fin</th><th>Total</th><th>Acciones</th></tr>
        </thead>
        <tbody>
            @foreach (var r in Model)
            {
                var clienteNombre  = clientes.FirstOrDefault(c => c.IdCliente   == r.IdCliente)?.Nombre   ?? r.IdCliente.ToString();
                var empleadoNombre = empleados.FirstOrDefault(e => e.IdEmpleado == r.IdEmpleado)?.Nombre  ?? r.IdEmpleado.ToString();
                var hotelNombre    = hoteles.FirstOrDefault(h => h.IdHotel      == r.IdHotel)?.Nombre     ?? r.IdHotel.ToString();
                <tr>
                    <td>@r.IdReservacion</td>
                    <td>@clienteNombre</td>
                    <td>@empleadoNombre</td>
                    <td>@hotelNombre</td>
                    <td>@r.FechaInicio</td>
                    <td>@r.FechaFin</td>
                    <td>Q @r.Total</td>
                    <td class="actions">
                        <a asp-action="Editar" asp-route-id="@r.IdReservacion" class="btn btn-sm btn-edit">Editar</a>
                        <form asp-action="Eliminar" asp-route-id="@r.IdReservacion" method="post" style="display:inline"
                              onsubmit="return confirm('¿Eliminar reservación #@r.IdReservacion?')">
                            <button type="submit" class="btn btn-sm btn-danger">Eliminar</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
